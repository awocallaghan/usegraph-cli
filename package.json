{
  "name": "@usegraph/cli",
  "version": "0.1.0",
  "description": "CLI tool for usegraph",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "usegraph": "dist/index.js"
  },
  "scripts": {
    "dev:dashboard": "node scripts/dev-dashboard.js",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "node --test tests/*.test.js",
    "test:dashboard": "node --test tests/dashboard-e2e.playwright.js",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "graph"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.1",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "playwright": "^1.58.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@observablehq/framework": "^1.13.0",
    "@swc/core": "^1.10.0",
    "@tmcp/adapter-zod": "^0.1.7",
    "@tmcp/transport-stdio": "^0.4.1",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "duckdb": "^1.4.4",
    "fast-glob": "^3.3.2",
    "tmcp": "^1.19.2",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
